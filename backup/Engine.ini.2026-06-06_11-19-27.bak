r.Lumen.ScreenProbeGather.RadianceCache=1
r.Lumen.ScreenProbeGather.DownsampleFactor=8
r.Nanite=1
r.ViewDistanceScale=1.5
r.CastShadows=1
r.ShadowQuality=4
r.Shadow.Virtual.Enable=1
r.ContactShadows=1
r.AmbientOcclusionLevels=3
