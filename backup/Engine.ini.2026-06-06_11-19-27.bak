r.SSR.Quality=3
r.VolumetricFog=1
r.VolumetricFog.GridPixelSize=8
r.Streaming.PoolSize=4096
r.Streaming.LimitPoolSizeToVRAM=1
r.TextureStreaming=1
r.Streaming.DefragDynamicBounds=1
r.MaxAnisotropy=12
r.FilmGrain=1
r.SceneColorFringeQuality=0
r.Tonemapper.GrainQuantization=1
r.RHICmdUseThread=1
r.RHICmdUseParallelAlgorithms=1
r.ParallelInitViews=1
r.ParallelRendering=1
r.ParallelMeshDrawCommands=1
r.AsyncCompute=1
r.AllowMultiThreadedShaderCreation=1
r.D3D12.ExecuteContextInParallel=1
r.D3D12.UseAllowTearing=1
s.AsyncLoadingThreadEnabled=1
s.AsyncLoadingTimeLimit=5.0
s.IoDispatcherBufferSizeMB=64
s.IoDispatcherCacheSizeMB=768
r.IO.UseDirectStorage=1
r.Reflex.Enable=1
r.Reflex.Boost=1
r.NGX.Enable=1
r.DynamicRes.OperationMode=1
r.Water.EnableShallowWaterSimulation=1
r.Water.SingleLayer.Reflection=2
r.SkyAtmosphereAsyncCompute=1
r.SceneDepthHZBAsyncCompute=2
r.Fog.HZBAsyncCompute=0
r.CustomDepth=3
r.Nanite.MaterialVisibility=1
r.BloomQuality=4
r.DepthOfFieldQuality=1
r.MotionBlurQuality=0
r.LensFlareQuality=1
r.PostProcessAAQuality=5
r.RayTracing=0
r.FilmGrainIntensity=0.5
sg.DefaultScalabilityLevel=3
r.PSOPrecache.Mode=1
r.OneFrameThreadLag=0
r.Shadow.CSM.MaxCascades=4
r.Shadow.MaxResolution=2048
r.ReflectionEnvironment=1
r.GenerateMeshDistanceFields=1
r.DistanceFieldShadowing=1
foliage.DensityScale=1.0
grass.DensityScale=1.0
r.HZBOcclusion=1
r.Tonemapper.Sharpen=0.1
r.Streaming.FramesForFullUpdate=4
r.Streaming.Boost=1

